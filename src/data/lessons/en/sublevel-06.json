      "items": [
        { "id": "f1", "front": "I am", "back": "Yo soy / estoy", "example": "I am happy." },
        { "id": "f2", "front": "You are", "back": "Tú eres / estás", "example": "You are my friend." },
        { "id": "f3", "front": "He is", "back": "Él es / está", "example": "He is a doctor." },
        { "id": "f4", "front": "She is", "back": "Ella es / está", "example": "She is at home." },
        { "id": "f5", "front": "It is", "back": "Es / Está (cosas/animales)", "example": "It is cold today." },
        { "id": "f6", "front": "We are", "back": "Nosotros somos / estamos", "example": "We are friends." },
        { "id": "f7", "front": "They are", "back": "Ellos son / están", "example": "They are students." },
        { "id": "f8", "front": "I am not", "back": "No soy / no estoy", "example": "I am not tired." },
        { "id": "f9", "front": "Is she…?", "back": "¿Ella es/está…?", "example": "Is she your sister?" }
      ]
    },
