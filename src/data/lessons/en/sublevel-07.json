      "type": "multiple_choice",
      "title": "What time is it?",
      "items": [
        {
          "id": "mc1",
          "prompt": "The clock shows 3:00. What do you say?",
          "options": ["It's three past.", "It's three o'clock.", "It's half three.", "It's quarter three."],
          "correctIndex": 1,
          "explanation": "For exact hours we say 'It's [number] o'clock'."
        },
        {
          "id": "mc2",
          "prompt": "The clock shows 7:30. What do you say?",
          "options": ["It's seven thirty past.", "It's half past eight.", "It's half past seven.", "It's quarter past seven."],
          "correctIndex": 2,
          "explanation": "'Half past seven' = 7:30. 'Half past' always means 30 minutes after."
        },
        {
          "id": "mc3",
          "prompt": "The clock shows 9:15. What do you say?",
          "options": ["It's nine fifteen past.", "It's quarter past nine.", "It's quarter to nine.", "It's half past nine."],
          "correctIndex": 1,
          "explanation": "'Quarter past' = 15 minutes after the hour."
        },
        {
          "id": "mc4",
          "prompt": "The clock shows 5:45. What do you say?",
          "options": ["It's quarter past six.", "It's quarter past five.", "It's quarter to six.", "It's half past five."],
          "correctIndex": 2,
          "explanation": "'Quarter to six' = 15 minutes before 6 = 5:45."
        },
        {
          "id": "mc5",
          "prompt": "Your class starts at 8:00 AM. How do you say this?",
          "options": ["My class starts at eight in the afternoon.", "My class starts at eight in the morning.", "My class starts at half past eight.", "My class starts at midnight."],
          "correctIndex": 1,
          "explanation": "AM = in the morning. 8:00 AM = eight in the morning."
        }
      ]
    },
