    {
      "id": "en-12-act-2",
      "type": "multiple_choice",
      "title": "Describe the person",
      "items": [
        {
          "id": "mc1",
          "prompt": "Someone who works a lot and never complains is ___.",
          "options": ["lazy", "shy", "hardworking", "outgoing"],
          "correctIndex": 2,
          "explanation": "'Hardworking' = trabajador. The opposite is 'lazy' (perezoso)."
        },
        {
          "id": "mc2",
          "prompt": "She doesn't talk much in a group — she is ___.",
          "options": ["outgoing", "tall", "funny", "shy"],
          "correctIndex": 3,
          "explanation": "'Shy' (tímido) = someone who is quiet or nervous in social situations."
        },
        {
          "id": "mc3",
          "prompt": "His hair is not straight — it has curls. His hair is ___.",
          "options": ["wavy", "curly", "long", "short"],
          "correctIndex": 1,
          "explanation": "'Curly' = rizado. 'Wavy' = ondulado (a softer wave)."
        },
        {
          "id": "mc4",
          "prompt": "She is 1.70 m. He is 1.60 m. She is ___ than him.",
          "options": ["shorter", "younger", "taller", "older"],
          "correctIndex": 2,
          "explanation": "1.70 > 1.60, so she is taller. 'Taller' = más alta."
        },
        {
          "id": "mc5",
          "prompt": "To describe eye colour you say: 'She ___ brown eyes.'",
          "options": ["is", "has", "have", "looks"],
          "correctIndex": 1,
          "explanation": "Physical features use 'have/has': 'She has brown eyes.'"
        }
      ]
    },
