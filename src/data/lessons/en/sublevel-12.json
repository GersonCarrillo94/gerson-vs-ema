        { "id": "f1", "front": "tall / short", "back": "alto / bajo", "example": "Gerson is tall. Ema is not short." },
        { "id": "f2", "front": "young / old", "back": "joven / mayor (viejo)", "example": "She looks young for her age." },
        { "id": "f3", "front": "long hair / short hair", "back": "cabello largo / corto", "example": "She has long, curly hair." },
        { "id": "f4", "front": "straight / curly / wavy", "back": "liso / rizado / ondulado", "example": "He has straight black hair." },
        { "id": "f5", "front": "blue / brown / green eyes", "back": "ojos azules / cafés / verdes", "example": "She has beautiful green eyes." },
        { "id": "f6", "front": "friendly / funny", "back": "amable / gracioso", "example": "He is very friendly and funny." },
        { "id": "f7", "front": "hardworking / lazy", "back": "trabajador / perezoso", "example": "She is hardworking and always on time." },
        { "id": "f8", "front": "shy / outgoing", "back": "tímido / extrovertido", "example": "At first he was shy, but now he is outgoing." },
        { "id": "f9", "front": "He / She looks like…", "back": "Él / Ella se parece a…", "example": "She looks like her mother." }
