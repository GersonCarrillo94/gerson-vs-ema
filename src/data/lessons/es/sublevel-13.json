        { "id": "f1", "front": "Verbos -AR: hablar", "back": "hablo, hablas, habla, hablamos, habláis, hablan", "example": "Yo hablo español. Ella habla inglés." },
        { "id": "f2", "front": "Verbos -ER: comer", "back": "como, comes, come, comemos, coméis, comen", "example": "Nosotros comemos a las dos." },
        { "id": "f3", "front": "Verbos -IR: vivir", "back": "vivo, vives, vive, vivimos, vivís, viven", "example": "Ellos viven en Bogotá." },
        { "id": "f4", "front": "Negación: no + verbo", "back": "No hablo chino. No come carne.", "example": "Yo no hablo francés. Él no come pescado." },
        { "id": "f5", "front": "Pregunta: ¿verbo + sujeto?", "back": "¿Hablas inglés? ¿Come ella aquí?", "example": "¿Hablas español? ¿Vive ella cerca?" },
        { "id": "f6", "front": "siempre / normalmente / a menudo", "back": "always / usually / often", "example": "Siempre desayuno. Normalmente camino." },
        { "id": "f7", "front": "a veces / casi nunca / nunca", "back": "sometimes / rarely / never", "example": "A veces veo películas. Nunca tomo café." },
        { "id": "f8", "front": "todos los días / una vez a la semana", "back": "every day / once a week", "example": "Estudio español todos los días." }
