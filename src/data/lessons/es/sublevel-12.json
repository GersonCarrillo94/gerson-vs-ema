      "title": "Describe a la persona",
      "items": [
        {
          "id": "mc1",
          "prompt": "Alguien que trabaja mucho y nunca se queja es ___.",
          "options": ["perezoso", "tímido", "trabajador", "extrovertido"],
          "correctIndex": 2,
          "explanation": "'Trabajador' = hardworking. Lo contrario es 'perezoso' (lazy)."
        },
        {
          "id": "mc2",
          "prompt": "Ella no habla mucho en grupo. Es ___.",
          "options": ["extrovertida", "alta", "graciosa", "tímida"],
          "correctIndex": 3,
          "explanation": "'Tímida' = shy. Alguien callado o nervioso en situaciones sociales."
        },
        {
          "id": "mc3",
          "prompt": "Su cabello no es liso — tiene rizos. Su cabello es ___.",
          "options": ["ondulado", "rizado", "largo", "corto"],
          "correctIndex": 1,
          "explanation": "'Rizado' = curly. 'Ondulado' = wavy (ondas más suaves)."
        },
        {
          "id": "mc4",
          "prompt": "Ella mide 1.70 m. Él mide 1.60 m. Ella es ___ que él.",
          "options": ["más baja", "más joven", "más alta", "más mayor"],
          "correctIndex": 2,
          "explanation": "1.70 > 1.60, entonces ella es más alta."
        },
        {
          "id": "mc5",
          "prompt": "Para describir el color de ojos dices: 'Ella ___ ojos cafés.'",
          "options": ["es", "tiene", "hay", "parece"],
          "correctIndex": 1,
          "explanation": "Las características físicas usan 'tener': 'Ella tiene ojos cafés'."
        }
      ]
    },
