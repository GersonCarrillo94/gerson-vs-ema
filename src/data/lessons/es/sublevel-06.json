      "title": "SER vs ESTAR",
      "items": [
        { "id": "f1", "front": "SER — identidad permanente", "back": "who/what you ARE", "example": "Soy colombiano. Eres médica." },
        { "id": "f2", "front": "ESTAR — estado temporal/lugar", "back": "how you feel / where you are", "example": "Estoy cansada. Estamos en casa." },
        { "id": "f3", "front": "Yo soy", "back": "I am (identity)", "example": "Soy estudiante." },
        { "id": "f4", "front": "Yo estoy", "back": "I am (state/location)", "example": "Estoy feliz hoy." },
        { "id": "f5", "front": "Él/Ella es", "back": "He/She is (identity)", "example": "Ella es profesora." },
        { "id": "f6", "front": "Él/Ella está", "back": "He/She is (state/location)", "example": "Él está enfermo." },
        { "id": "f7", "front": "Ellos son", "back": "They are (identity)", "example": "Son amigos." },
        { "id": "f8", "front": "Ellos están", "back": "They are (state/location)", "example": "Están en el parque." }
      ]
    },
