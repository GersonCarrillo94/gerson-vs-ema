      "items": [
        { "id": "f1", "front": "¿Qué hora es?", "back": "What time is it?", "example": "Perdona, ¿qué hora es?" },
        { "id": "f2", "front": "Es la una.", "back": "It's one o'clock.", "example": "Es la una de la mañana." },
        { "id": "f3", "front": "Son las tres.", "back": "It's three o'clock.", "example": "La reunión es a las tres." },
        { "id": "f4", "front": "Son las dos y media.", "back": "It's half past two.", "example": "Quedamos a las dos y media." },
        { "id": "f5", "front": "Son las cuatro y cuarto.", "back": "It's quarter past four.", "example": "La clase empieza a las cuatro y cuarto." },
        { "id": "f6", "front": "Son las seis menos cuarto.", "back": "It's quarter to six.", "example": "¡Apúrate! Son las seis menos cuarto." },
        { "id": "f7", "front": "de la mañana", "back": "in the morning / AM", "example": "Me levanto a las siete de la mañana." },
        { "id": "f8", "front": "de la tarde / de la noche", "back": "in the afternoon / evening / PM", "example": "Estudiamos a las tres de la tarde." },
        { "id": "f9", "front": "al mediodía / a medianoche", "back": "at noon / at midnight", "example": "Almorzamos al mediodía." }
