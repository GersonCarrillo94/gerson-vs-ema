      "type": "multiple_choice",
      "title": "¿Qué hora es?",
      "items": [
        {
          "id": "mc1",
          "prompt": "El reloj marca las 3:00. ¿Qué dices?",
          "options": ["Son las tres menos.", "Es la tres en punto.", "Son las tres en punto.", "Son las tres y media."],
          "correctIndex": 2,
          "explanation": "'Son las…' para 2 en adelante. 'En punto' = exact hour. Excepción: 'Es la una'."
        },
        {
          "id": "mc2",
          "prompt": "El reloj marca las 7:30. ¿Cómo lo dices?",
          "options": ["Son las siete y cuarto.", "Son las ocho menos media.", "Son las siete y media.", "Es la siete y media."],
          "correctIndex": 2,
          "explanation": "'Y media' = 30 minutos. 'Son las siete y media' = 7:30."
        },
        {
          "id": "mc3",
          "prompt": "El reloj marca las 9:15. ¿Cómo lo dices?",
          "options": ["Son las nueve menos cuarto.", "Son las nueve y cuarto.", "Son las diez menos cuarto.", "Son las nueve y media."],
          "correctIndex": 1,
          "explanation": "'Y cuarto' = 15 minutos después de la hora. 9:15 = 'las nueve y cuarto'."
        },
        {
          "id": "mc4",
          "prompt": "El reloj marca las 5:45. ¿Cómo lo dices?",
          "options": ["Son las cinco y cuarto.", "Son las seis y cuarto.", "Son las seis menos cuarto.", "Son las cinco menos cuarto."],
          "correctIndex": 2,
          "explanation": "'Menos cuarto' = 15 minutos antes de la siguiente hora. 5:45 = 'las seis menos cuarto'."
        },
        {
          "id": "mc5",
          "prompt": "Tu clase empieza a las 8:00 AM. ¿Cómo lo dices?",
          "options": ["Mi clase empieza a las ocho de la tarde.", "Mi clase empieza a las ocho de la mañana.", "Mi clase empieza a las ocho y media.", "Mi clase empieza al mediodía."],
          "correctIndex": 1,
          "explanation": "AM = de la mañana. 8:00 AM = ocho de la mañana."
        }
      ]
    },
