          "explanation": "Ellos → están + preparando. 'En este momento' confirma la acción en curso."
        },
        {
          "id": "mc3",
          "prompt": "Él ___ música. Tiene los auriculares puestos.",
          "options": ["escucha", "escuchó", "está escuchando", "están escuchando"],
