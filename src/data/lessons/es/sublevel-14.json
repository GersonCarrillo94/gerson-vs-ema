  "activities": [
    {
      "id": "es-14-act-1",
      "type": "flashcards",
      "title": "Estructura del presente continuo",
      "items": [
        { "id": "f1", "front": "Yo estoy + gerundio", "back": "I am + -ing", "example": "Estoy estudiando ahora mismo." },
        { "id": "f2", "front": "Él / Ella está + gerundio", "back": "He/She is + -ing", "example": "Ella está trabajando desde casa hoy." },
        { "id": "f3", "front": "Nosotros estamos + gerundio", "back": "We are + -ing", "example": "Estamos viendo una película." },
        { "id": "f4", "front": "Negación: no está / no estoy", "back": "isn't / aren't + -ing", "example": "No está durmiendo. No estamos comiendo." },
        { "id": "f5", "front": "Pregunta: ¿Está…? ¿Estás…?", "back": "Is she…? Are you…?", "example": "¿Está comiendo? ¿Estás escuchando?" },
        { "id": "f6", "front": "ahora mismo / en este momento", "back": "right now / at the moment", "example": "No puedo hablar — estoy conduciendo ahora mismo." },
        { "id": "f7", "front": "Gerundio -AR: hablar → hablando", "back": "speak → speaking", "example": "Estoy hablando con mi madre." },
        { "id": "f8", "front": "Gerundio -ER/-IR: comer → comiendo, vivir → viviendo", "back": "eat → eating, live → living", "example": "Ella está comiendo. Están viviendo juntos." }
      ]
    },
    {
      "id": "es-14-act-2",
      "type": "multiple_choice",
      "title": "Presente simple vs continuo",
      "items": [
        {
          "id": "mc1",
          "prompt": "Ella ___ ahora mismo. No la molestes.",
          "options": ["estudia", "está estudiando", "estudió", "estudiará"],
          "correctIndex": 1,
          "explanation": "'Ahora mismo' indica el presente continuo: está + estudiando."
        },
        {
          "id": "mc2",
          "prompt": "Ellos ___ la cena en este momento.",
          "options": ["preparan", "están preparando", "está preparando", "preparaban"],
