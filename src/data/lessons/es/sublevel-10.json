      "title": "Elige el verbo correcto",
      "items": [
        {
          "id": "mc1",
          "prompt": "Yo ___ dos hermanas y un hermano.",
          "options": ["voy", "tengo", "hago", "quiero"],
          "correctIndex": 1,
          "explanation": "'Tener' se usa para hablar de posesiones y relaciones familiares."
        },
        {
          "id": "mc2",
          "prompt": "Ella ___ al gimnasio todos los lunes.",
          "options": ["hace", "va", "tiene", "gusta"],
          "correctIndex": 1,
          "explanation": "'Ir' = to go. Con 'ella' usamos 'va'. 'Ella va al gimnasio'."
        },
        {
          "id": "mc3",
          "prompt": "Yo ___ un café. ¿Puedes preparar uno?",
          "options": ["voy", "veo", "necesito", "vengo"],
          "correctIndex": 2,
          "explanation": "'Necesitar' = to need. 'Necesito un café' = I need a coffee."
        },
        {
          "id": "mc4",
          "prompt": "'¿___ su nombre?' — 'No, no lo sé.'",
          "options": ["Tienes", "Sabes", "Eres", "Vas"],
          "correctIndex": 1,
          "explanation": "'Saber' se usa para conocer datos o información. '¿Sabes su nombre?'"
        },
        {
          "id": "mc5",
          "prompt": "A mí me ___ el español porque abre puertas.",
          "options": ["necesita", "tengo", "gusta", "quiero"],
          "correctIndex": 2,
          "explanation": "'Gustar' funciona diferente: 'Me gusta el español' (no 'yo gusto el español')."
        }
      ]
    },
