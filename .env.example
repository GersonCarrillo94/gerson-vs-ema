# Supabase
# Obtén estos valores en: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Daily.co (videollamadas)
# Crea cuenta gratis en https://dashboard.daily.co/
VITE_DAILY_DOMAIN=YOUR_DOMAIN.daily.co

# IMPORTANTE: la API key de Daily SOLO va en variables de Supabase Edge Functions,
# NUNCA en el cliente. La incluimos aquí como referencia pero no debe estar en VITE_*.
# DAILY_API_KEY=YOUR_SERVER_KEY
